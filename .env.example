# ─────────────────────────────────────────────────────────────────────
# Negotium — Environment Variables
#
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# Discord webhook URL (leave empty to disable)
DISCORD_WEBHOOK_URL=

# OpenAI API key for LLM job ranking (leave empty to disable)
OPENAI_API_KEY=
